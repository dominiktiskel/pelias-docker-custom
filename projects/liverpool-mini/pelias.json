{
  "logger": {
    "level": "info",
    "timestamp": false
  },
  "esclient": {
    "apiVersion": "7.5",
    "hosts": [
      {
        "host": "elasticsearch"
      }
    ]
  },
  "elasticsearch": {
    "settings": {
      "index": {
        "refresh_interval": "10s",
        "number_of_replicas": "0",
        "number_of_shards": "1"
      }
    }
  },
  "acceptance-tests": {
    "endpoints": {
      "docker": "http://api:4000/v1/"
    }
  },
  "api": {
    "services": {
      "libpostal": {
        "url": "http://libpostal:4400"
      }
    },
    "defaultParameters": {
      "focus.point.lat": 53.4084,
      "focus.point.lon": -2.9916
    }
  },
  "imports": {
    "adminLookup": {
      "enabled": true
    },
    "whosonfirst": {
      "datapath": "/data/whosonfirst"
    },
    "openstreetmap": {
      "download": [
        {
          "sourceURL": "https://download.bbbike.org/osm/bbbike/Liverpool/Liverpool.osm.pbf"
        }
      ],
      "leveldbpath": "/tmp",
      "datapath": "/data/openstreetmap",
      "import": [
        {
          "filename": "Liverpool.osm.pbf",
          "countryCode": "GB"
        }
      ],
      "preferOsmAdmin": true,
      "useV2Pipeline": true,
      "aggregateHouseNumbers": true,
      "importStreets": true
    }
  }
}
